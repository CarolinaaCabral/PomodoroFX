<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="30.0"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.meuprojeto.pomodorofx.PomodoroController"
      styleClass="@style.css">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Label fx:id="timerLabel" text="25:00" styleClass="timer-label"/>

    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="startButton" onAction="#handleStart" text="Iniciar" styleClass="btn-primary"/>
        <Button fx:id="resetButton" onAction="#handleReset" text="Resetar" styleClass="btn-secondary"/>
    </HBox>
</VBox>